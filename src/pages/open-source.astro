---
import { getCollection } from "astro:content";
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/Container.astro";
import Link from "@components/Link.astro";
import { OPEN_SOURCE } from "@consts";

// Fetch projects with repo links to display as open-source codebases
const projects = (await getCollection("projects"))
  .filter(p => !p.data.draft && p.data.repoURL)
  .sort((a, b) => (a.data.importance ?? 10) - (b.data.importance ?? 10));

// Mock or static documentation of core upstream contributions (matching internship/experience)
const upstreamContributions = [
  {
    project: "Linux Kernel",
    repo: "https://github.com/torvalds/linux",
    description: "Patched a race condition in kernel slab memory allocation under heavy network queue contention.",
    technologies: ["C", "Kernel Programming", "Memory Management"],
    date: "Aug 2025"
  },
  {
    project: "RocksDB",
    repo: "https://github.com/facebook/rocksdb",
    description: "Contributed fixes to memory alignment in block-based table builders for arm64 architectures.",
    technologies: ["C++", "Storage Systems", "Performance Tuning"],
    date: "July 2024"
  }
];
---

<PageLayout title={OPEN_SOURCE.TITLE} description={OPEN_SOURCE.DESCRIPTION}>
  <Container>
    <div class="space-y-12">
      <!-- Intro Section -->
      <section class="animate space-y-4">
        <h3 class="font-semibold text-black dark:text-white text-2xl">
          Open Source Contributions
        </h3>
        <p class="leading-relaxed text-neutral-800 dark:text-neutral-300">
          I believe in building open, high-performance systems and contributing back to core infrastructure. Below are some key open source repositories I maintain, along with upstream contributions to foundations like the Linux Kernel and RocksDB.
        </p>
      </section>

      <!-- Featured Repositories -->
      <section class="animate space-y-6">
        <h4 class="font-semibold text-black dark:text-white text-xl">
          Featured Projects
        </h4>
        <div class="grid grid-cols-1 gap-6">
          {projects.map(proj => (
            <div class="border border-black/10 dark:border-white/10 rounded-xl p-5 bg-neutral-50 dark:bg-neutral-900/50 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition duration-200">
              <div class="flex justify-between items-start flex-wrap gap-2 mb-2">
                <h5 class="font-bold text-lg text-neutral-900 dark:text-neutral-100">
                  {proj.data.title}
                </h5>
                <span class="text-xs text-neutral-500 dark:text-neutral-400 font-medium">
                  {proj.data.date}
                </span>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300 mb-4">
                {proj.data.description}
              </p>
              <div class="flex flex-wrap gap-2 mb-4">
                {proj.data.skills.map((skill: string) => (
                  <span class="px-2 py-0.5 text-[10px] font-bold rounded bg-blue-100 dark:bg-blue-900/40 text-blue-800 dark:text-blue-300">
                    {skill}
                  </span>
                ))}
              </div>
              {proj.data.repoURL && (
                <Link href={proj.data.repoURL} external class="text-sm font-semibold text-blue-700 dark:text-blue-400 hover:underline inline-flex items-center gap-1">
                  View Repository
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                  </svg>
                </Link>
              )}
            </div>
          ))}
        </div>
      </section>

      <!-- Upstream Work -->
      <section class="animate space-y-6">
        <h4 class="font-semibold text-black dark:text-white text-xl">
          Upstream Contributions
        </h4>
        <div class="space-y-6">
          {upstreamContributions.map(contrib => (
            <div class="border-l-2 border-blue-600 pl-4 space-y-2">
              <div class="flex justify-between items-baseline flex-wrap gap-x-2">
                <h5 class="font-bold text-neutral-900 dark:text-neutral-100 text-lg">
                  <a href={contrib.repo} target="_blank" class="hover:underline text-blue-700 dark:text-blue-400 inline-flex items-center gap-1.5">
                    {contrib.project}
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="size-3.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                    </svg>
                  </a>
                </h5>
                <span class="text-sm text-neutral-500 dark:text-neutral-400 font-medium">
                  {contrib.date}
                </span>
              </div>
              <p class="text-sm text-neutral-700 dark:text-neutral-300">
                {contrib.description}
              </p>
              <div class="flex flex-wrap gap-1.5 mt-2">
                {contrib.technologies.map(tech => (
                  <span class="px-2 py-0.5 text-[10px] rounded bg-neutral-200 dark:bg-neutral-800 text-neutral-700 dark:text-neutral-300 font-medium">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </section>
    </div>
  </Container>
</PageLayout>

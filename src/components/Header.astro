---
import { NAV_LINKS, CONTACT, resolvePath } from '../consts';
import ThemeIcon from './ThemeIcon.astro';

const currentPath = Astro.url.pathname;
---

<header id="site-header">
	<div class="header-inner">
		<a href={resolvePath('/')} class="logo" id="nav-home-logo">murtaza</a>

		<button
			class="menu-toggle"
			id="menu-toggle"
			aria-label="Toggle menu"
			aria-expanded="false"
			aria-controls="nav-menu"
		>
			<svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
				<line x1="4" y1="6" x2="20" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				<line x1="4" y1="12" x2="20" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
				<line x1="4" y1="18" x2="20" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
			</svg>
		</button>

		<nav class="nav-menu" id="nav-menu" aria-label="Main navigation">
			{NAV_LINKS.map((link) => (
				<a
					href={resolvePath(link.href)}
					class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}
					id={`nav-${link.label.toLowerCase().replace(/\s+/g, '-')}`}
				>
					{link.label}
				</a>
			))}
			<span class="nav-divider"></span>
			<div class="social-links">
				<ThemeIcon />
				<a href={CONTACT.github} target="_blank" rel="noopener noreferrer" aria-label="GitHub">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
						><path
							fill="currentColor"
							d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
						></path></svg
					>
				</a>
				<a href={CONTACT.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
					<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
						><path
							fill="currentColor"
							d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
						></path></svg
					>
				</a>
			</div>
		</nav>
	</div>
</header>

<script>
	const toggle = document.getElementById('menu-toggle');
	const menu = document.getElementById('nav-menu');

	toggle?.addEventListener('click', () => {
		const isOpen = menu?.classList.toggle('open');
		toggle.setAttribute('aria-expanded', String(isOpen));
	});
</script>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 100;
		background: var(--color-bg-base);
		border-bottom: 1px solid rgb(var(--gray-light));
	}

	.header-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 0 1em;
		height: 56px;
	}

	/* Logo */
	.logo {
		font-weight: 700;
		font-size: 1.1rem;
		color: rgb(var(--black));
		text-decoration: none;
		letter-spacing: -0.02em;
	}
	.logo:hover {
		color: var(--accent);
		text-decoration: none;
	}

	/* Hamburger (hidden on desktop) */
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		color: rgb(var(--gray-dark));
		cursor: pointer;
		padding: 0.4em;
		border-radius: 4px;
	}
	.menu-toggle:hover {
		background: rgba(var(--gray-light), 60%);
	}

	/* Nav */
	.nav-menu {
		display: flex;
		align-items: center;
		gap: 0.25em;
	}

	.nav-menu a {
		padding: 0.4em 0.6em;
		font-size: 0.9rem;
		color: rgb(var(--gray));
		text-decoration: none;
		border-radius: 6px;
		transition: color 0.15s, background-color 0.15s;
	}
	.nav-menu a:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray-light), 40%);
		text-decoration: none;
	}
	.nav-menu a.active {
		color: rgb(var(--black));
		font-weight: 600;
	}

	/* Divider between nav links and social icons */
	.nav-divider {
		width: 1px;
		height: 20px;
		background: rgb(var(--gray-light));
		margin: 0 0.4em;
	}

	/* Social icons */
	.social-links {
		display: flex;
		align-items: center;
		gap: 0.15em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.35em;
		color: rgb(var(--gray));
		border-radius: 6px;
	}
	.social-links a:hover {
		color: rgb(var(--black));
		background: rgba(var(--gray-light), 40%);
	}

	/* --- Mobile --- */
	@media (max-width: 720px) {
		.menu-toggle {
			display: flex;
			align-items: center;
		}

		.nav-menu {
			display: none;
			position: absolute;
			top: 56px;
			left: 0;
			right: 0;
			background: var(--color-bg-base);
			border-bottom: 1px solid rgb(var(--gray-light));
			flex-direction: column;
			align-items: stretch;
			padding: 0.5em 1em 1em;
			box-shadow: 0 4px 12px rgba(var(--black), 5%);
		}

		.nav-menu.open {
			display: flex;
		}

		.nav-menu a {
			padding: 0.65em 0.6em;
			font-size: 1rem;
		}

		.nav-divider {
			width: 100%;
			height: 1px;
			margin: 0.4em 0;
		}

		.social-links {
			padding: 0.25em 0.3em;
			gap: 0.5em;
		}
	}
</style>
